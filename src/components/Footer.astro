---
import CallToAction from './CallToAction.astro'
import Logo from './Logo.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import themeConfig from '@theme-config'

/**
 * Footer Component
 *
 * @description The site footer with navigation, social links, and copyright.
 */
const currentYear = new Date().getFullYear()
const socials = themeConfig.socials ?? []
---

<footer>
  <section class="py-20">
    <Heading level="h2" class="sr-only">Footer</Heading>
    <div class="container grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Explore</Heading>
        <ul class="flex flex-col gap-2">
          <li><Link href="/#about">About</Link></li>
          <li><Link href="/#scholarship">Scholarship</Link></li>
          <li><Link href="/#education">Education</Link></li>
          <li><Link href="/#organizing">Organizing</Link></li>
          <li><Link href="/contact">Contact</Link></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Connect</Heading>
        <ul class="flex flex-col gap-2">
          {
            socials.map((social) => (
              <li>
                <Link isExternal href={social.href}>
                  <Icon aria-hidden="true" name={social.icon} size="1.25rem" />
                  {social.label}
                </Link>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Logo loading="lazy" />
        <p class="leading-[1.75]">
          Dialectical praxis — the fusion of critical reflection and transformative action in pursuit of collective
          liberation.
        </p>
      </div>
    </div>
  </section>
  <section class="py-8">
    <div class="container flex flex-col gap-4 md:flex-row md:justify-between">
      <p>&copy; {currentYear} Derron Borders · Dialectical Praxis.</p>
      <p>
        Built with <Link href="https://astro.build/">Astro</Link> and the <Link
          href="https://github.com/incluud/accessible-astro-starter">Accessible Astro Starter</Link
        >.
      </p>
    </div>
  </section>
</footer>

<style>
  section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
