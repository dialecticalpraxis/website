---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Link } from 'accessible-astro-components'
import { Button } from 'accessible-astro-components'
import { Badge } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import { Notification } from 'accessible-astro-components'
---

<DefaultLayout title="Scholarship">
  <section class="my-12">
    <PageHeader
      title="Scholarship"
      subtitle=""
      bgType="bordered"
    />
  </section>

<div class="flex justify-center">
    <Link href="/scholarship/cv" isButton size="lg" animateOnHover animationType="nudge">
  View my Curriculum Vitae
  <Icon aria-hidden="true" name="lucide:mouse-pointer-click" size="1.5rem" />
</Link>
</div>