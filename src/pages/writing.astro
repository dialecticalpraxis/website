---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Card, Badge } from 'accessible-astro-components'
import { getCollection } from 'astro:content'
import defaultCover from '@assets/images/site/dplogo.png'

// Load all essays, drop drafts, newest first
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })
---

<DefaultLayout title="Writing">
  <PageHeader title="Writing" subtitle="Essays and reflections on the world." bgType="primary" />
  <section class="container my-16">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <Card
            imageComponent={post.data.cover ?? defaultCover}
            imageAlt={post.data.coverAlt || post.data.title}
            width={600}
            height={600}
            url={`/writing/${post.id}`}
            title={post.data.title}
            footer={formatDate(post.data.publishDate)}
            fullHeight
          >
            {post.data.tags.length > 0 && (
              <span slot="meta">
                {post.data.tags.map((tag) => (
                  <Badge size="sm">{tag}</Badge>
                ))}
              </span>
            )}
            {post.data.description}
          </Card>
        ))
      }
    </div>
  </section>
</DefaultLayout>
