---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Card, Badge } from 'accessible-astro-components'
import { getCollection } from 'astro:content'
import defaultCover from '@assets/images/site/dplogo.png'

// Load all projects, drop drafts, newest first (by publishDate when set, else by title)
const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => {
    const da = a.data.publishDate?.valueOf() ?? 0
    const db = b.data.publishDate?.valueOf() ?? 0
    if (db !== da) return db - da
    return a.data.title.localeCompare(b.data.title)
  })
---

<DefaultLayout title="Projects">
  <PageHeader
    title="Projects"
    subtitle="My personal projects and work related to education, scholarship, and organizing."
    bgType="primary"
  />
  <section class="container my-16">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => (
          <Card
            imageComponent={project.data.cover ?? defaultCover}
            imageAlt={project.data.coverAlt || project.data.title}
            width={600}
            height={600}
            url={`/projects/${project.id}`}
            title={project.data.title}
            fullHeight
          >
            {project.data.tags.length > 0 && (
              <span slot="meta">
                {project.data.tags.map((tag) => (
                  <Badge size="sm">{tag}</Badge>
                ))}
              </span>
            )}
            {project.data.description}
          </Card>
        ))
      }
    </div>
  </section>
</DefaultLayout>
