---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Badge } from 'accessible-astro-components'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts
    .filter((p) => !p.data.draft)
    .map((entry) => ({ params: { slug: entry.id }, props: { entry } }))
}

const { entry } = Astro.props
const { Content } = await render(entry)

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---

<DefaultLayout title={entry.data.title} description={entry.data.description}>
  <PageHeader title={entry.data.title} subtitle={entry.data.description} bgType="bordered" />
  <section class="container my-16">
    <div class="narrow container space-content">
      <p class="entry-meta">
        <time datetime={entry.data.publishDate.toISOString()}>{formatDate(entry.data.publishDate)}</time>
        {entry.data.author && <span> · {entry.data.author}</span>}
      </p>
      {
        entry.data.tags.length > 0 && (
          <div class="mb-8 flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <Badge size="sm">{tag}</Badge>
            ))}
          </div>
        )
      }
      <Content />
      <p class="mt-12"><a href="/writing">&larr; Back to all writing</a></p>
    </div>
  </section>
</DefaultLayout>

<style>
  .entry-meta {
    color: var(--color-neutral-700);
    font-size: var(--font-size--1);
  }
</style>
